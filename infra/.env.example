# infra/.env.example — copy to infra/.env and fill in real values.
# infra/.env is gitignored; this template is committed so the public repo
# documents the mechanism without exposing specific identifiers.

# GCP project the bucket lives in.
PROJECT="project-name"

# Bucket name — GLOBALLY UNIQUE across all of GCS, lowercase/digits/hyphens,
# 3-63 chars, and effectively permanent (no rename). Scope it to YOU and your
# projects, not to one product — the context bridge serves every project under
# ~/Projects, so it's one bucket for all of them.

BUCKET="bucket-name"

# Region. Match where the Cloud Run MCP server will run (us-central1 today).
REGION="us-central1"

# Service account the read-only MCP server will use to read the bucket.
# Created by setup-gcs.sh if absent. Just the short name here; the script
# expands it to <name>@<project>.iam.gserviceaccount.com.
READER_SA_NAME="context-bridge-reader"

# Lifecycle: auto-delete objects older than this many days.
LIFECYCLE_DAYS="30"
